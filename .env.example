# pss-production-card — environment variables
#
# Shared secrets (Supabase, doc service) come from ../platform-portal/.env at
# deploy time via env_file in docker-compose.app.yml. Values here are for local
# `next dev` only. Copy to .env and fill in.

# ── Supabase ──
# Cloud values in production; self-hosted values in dev. Mirror platform-portal/.env.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App identity ──
NEXT_PUBLIC_BASE_PATH=/production-card
NEXT_PUBLIC_APP_NAME=production-card

# ── pss-document-service (61355 numbering + traveller PDF storage) ──
DOC_SERVICE_URL=http://10.0.0.74:3000
DOC_SERVICE_API_KEY=

# ── Kiosk webhook (M5Stack RFID + barcode posts events here) ──
# Shared secret the firmware uses for HMAC; rotate when re-flashing.
KIOSK_HMAC_SECRET=
